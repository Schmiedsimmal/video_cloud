sw-vision-cloud.duckdns.org {
    reverse_proxy video-cloud:3000 {
        # Support large file uploads — no timeouts
        transport http {
            read_timeout 0
            write_timeout 0
            dial_timeout 30s
        }
    }

    # Increase upload limits
    request_body {
        max_size 20GB
    }

    # Compression for faster page loads
    encode gzip zstd
}
